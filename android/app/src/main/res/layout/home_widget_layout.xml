<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_recommendation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Safe to Wash"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:gravity="center" />

    <TextView
        android:id="@+id/widget_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Score: 75/100"
        android:textSize="16sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="12dp" />

    <TextView
        android:id="@+id/widget_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading location..."
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:gravity="center" />

    <TextView
        android:id="@+id/widget_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temp: 15.0°C | Humidity: 65%"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_status_indicator"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="12dp"
        android:background="#4CAF50"
        android:text="" />
</LinearLayout>
